{{ define "sttlist.page.tmpl" }}

{{ template "header" .}}

<div class="container-fluid">
  <div class="row">
    <div class="col">
      <h2>Speech to Text extracted</h2>
      <table class="table table-striped table-sm">
        <thead>
          <tr>
            <th scope="col">Extraction Date</th>
            <th scope="col">Source Name</th>
            <th scope="col">Text File Name</th>
            <th scope="col">Status</th>
            <th scope="col">Text</th>
          </tr>
        </thead>
        <tbody>
          {{ range .data }}
          <tr>
            <td>{{ .SttDate }}</td>
            <td>{{ .SourceFileName }}</td>
            <td>{{ .TextFileName }}</td>
            <td>{{ .Status }}</td>
            <td style="max-width: 28rem;">
              <details>
                <summary>
                  <span class="d-inline-block text-truncate"
                    style="max-width: 24rem;">
                    {{ .Text }}
                  </span>
                </summary>
                <div class="mt-2" style="white-space: pre-wrap;">
                  {{ .Text }}
                </div>
              </details>
            </td>
          </tr>
          {{ end }}
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
        setTimeout(function(){
        location.reload();}, 5000);
    </script>

{{ template "footer" .}}

{{ end }}
